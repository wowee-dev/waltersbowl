# Dinner Menu — environment variables
#
# Local development:
#   1. Copy this file to `.env` and set ADMIN_PASSWORD
#   2. Run `npm install` then `npm run dev`
#   3. Guest page: http://localhost:3001
#   4. Admin editor: http://localhost:3001/admin.html
#
# Vercel deployment:
#   1. Push this repo to GitHub and import it in Vercel
#   2. Add Upstash Redis from Vercel Marketplace (Storage → Redis)
#   3. Set ADMIN_PASSWORD and JWT_SECRET in Vercel project settings
#   4. Deploy — guests visit `/`, you edit at `/admin.html`

# Admin login password (required in production)
ADMIN_PASSWORD=choose-a-strong-password

# JWT signing secret (recommended in production; falls back to ADMIN_PASSWORD)
JWT_SECRET=replace-with-a-long-random-string

# Upstash Redis (required in production on Vercel — auto-set when Redis is linked)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local development
PORT=3001
